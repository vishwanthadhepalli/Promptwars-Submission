rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isMemberOfTeam(teamId) {
      let team = get(/databases/$(database)/documents/teams/$(teamId)).data;
      return isSignedIn() && (request.auth.uid in team.members || team.roles[request.auth.uid] != null);
    }

    function isAdminOfTeam(teamId) {
      let team = get(/databases/$(database)/documents/teams/$(teamId)).data;
      return isSignedIn() && (team.roles[request.auth.uid] == 'admin' || team.ownerId == request.auth.uid);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'createdAt']) &&
               data.email is string && data.email.size() > 0 &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn(); 
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isSignedIn() && request.auth.uid == userId && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'company'])
      );
    }

    // --- Teams ---
    match /teams/{teamId} {
      function isValidTeam(data) {
        return data.keys().hasAll(['ownerId', 'members', 'roles', 'createdAt']) &&
               data.ownerId == request.auth.uid &&
               data.members is list && data.members.size() > 0 &&
               data.roles is map && data.roles[request.auth.uid] == 'admin' &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn() && (request.auth.uid in resource.data.members || request.auth.token.email in resource.data.invitedEmails);
      allow create: if isSignedIn() && isValidTeam(request.resource.data);
      allow update: if isSignedIn() && (
        // Admin can manage team
        (isAdminOfTeam(teamId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'name', 'invitedEmails', 'roles'])) ||
        // User can join themselves if invited
        (request.auth.token.email in resource.data.invitedEmails && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'roles']) &&
         request.resource.data.members.hasAll(resource.data.members) &&
         request.resource.data.members.size() == resource.data.members.size() + 1 &&
         request.auth.uid in request.resource.data.members &&
         request.resource.data.roles[request.auth.uid] == 'member')
      );
    }

    // --- Tasks ---
    match /teams/{teamId}/tasks/{taskId} {
      function isValidTask(data) {
        return data.keys().hasAll(['title', 'priority', 'status', 'creatorId', 'createdAt', 'updatedAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.priority in ['low', 'medium', 'high'] &&
               data.status in ['todo', 'in-progress', 'done'] &&
               data.creatorId == request.auth.uid &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      function hasTaskWriteAccess(data) {
        return isSignedIn() && (
          data.creatorId == request.auth.uid || 
          data.assigneeId == request.auth.uid || 
          isAdminOfTeam(teamId)
        );
      }

      // Read access: Must be a member of the team
      allow read: if isMemberOfTeam(teamId);

      allow create: if isMemberOfTeam(teamId) && isValidTask(request.resource.data);
      allow update: if isMemberOfTeam(teamId) && hasTaskWriteAccess(resource.data) && (
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'priority', 'status', 'startDate', 'dueDate', 'assigneeId', 'collaboratorIds', 'tags', 'risk', 'updatedAt'])
      );
      allow delete: if isMemberOfTeam(teamId) && (resource.data.creatorId == request.auth.uid || isAdminOfTeam(teamId));
    }
  }
}
