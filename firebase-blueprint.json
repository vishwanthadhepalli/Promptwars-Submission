{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile for team members.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "teamIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["displayName", "email"]
    },
    "Team": {
      "title": "Team Workspace",
      "description": "A collaborative group space.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "ownerId", "members"]
    },
    "Task": {
      "title": "Task",
      "description": "An actionable item within a team.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "assignees": { "type": "array", "items": { "type": "string" } },
        "creatorId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "priority", "status", "creatorId"]
    },
    "Document": {
      "title": "Collaborative Document",
      "description": "Shared documentation for projects.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "creatorId": { "type": "string" },
        "lastModified": { "type": "string", "format": "date-time" },
        "collaborators": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "creatorId"]
    },
    "Insight": {
      "title": "AI Insight",
      "description": "Generated reports, briefings, or risk assessments.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["briefing", "risk", "report"] },
        "content": { "type": "string" },
        "targetId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles."
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Root team records."
    },
    "/teams/{teamId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks within a specific team."
    },
    "/teams/{teamId}/documents/{docId}": {
      "schema": "Document",
      "description": "Collaborative docs for the team."
    },
    "/teams/{teamId}/insights/{insightId}": {
      "schema": "Insight",
      "description": "AI-generated intelligence per team."
    }
  }
}
