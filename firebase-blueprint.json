{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the SaaS system",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "company": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Team": {
      "title": "Team",
      "description": "Collaborative workspace for tasks",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "invitedEmails": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "members", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Actionable item within a workspace",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "dueDate": { "type": "string" },
        "assigneeId": { "type": "string" },
        "creatorId": { "type": "string" },
        "collaboratorIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "priority", "status", "creatorId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public and private user details"
    },
    "teams/{teamId}": {
      "schema": "Team",
      "description": "Team metadata and membership"
    },
    "teams/{teamId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks scoped to a team"
    }
  }
}
